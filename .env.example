# Required — create your Discord webhook:
# Server Settings → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_TOKEN

# Optional — comma-separated. Leave blank to use the built-in defaults.
# Default includes: intern, internship, new grad, swe, software engineer,
#                   ml engineer, ai engineer, research engineer, machine learning, data scientist
KEYWORDS=intern,internship,new grad,swe,software engineer,ml engineer,ai engineer,research engineer

# Optional — comma-separated job title words to EXCLUDE (filters out senior/lead roles).
# Default: senior, staff, lead, director, principal, manager, vp, head of
EXCLUDED_KEYWORDS=senior,staff,lead,director,principal,manager,vp,head of

# Optional — only show jobs whose location contains one of these strings.
# Leave blank to see all locations (recommended to start).
# Example: remote,san francisco,new york,seattle
LOCATIONS=

# Optional — max Discord notifications per run (default: 25).
# Prevents spam if a company bulk-posts many roles at once.
MAX_NOTIFICATIONS_PER_RUN=25
