# ============================================================
# Multi-channel mode
# ============================================================
# Preferred for multiple Discord channels. Use a compact JSON list, or an
# object like {"channels":[...]} with the same channel objects.
# Leave blank to use channels.json locally or the single-channel fallback below.
CHANNELS_JSON=

# Optional local file path for multi-channel config.
CHANNELS_PATH=channels.json

# ============================================================
# Single-channel fallback
# ============================================================
# Create your Discord webhook:
# Server Settings → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_TOKEN

# ============================================================
# Job filtering  (leave blank to use the built-in defaults)
# ============================================================

# Comma-separated keywords matched against job titles (whole-word, case-insensitive).
# A job must match AT LEAST ONE keyword to be notified.
# Default covers internships, new grad, and common entry-level role types.
KEYWORDS=intern,internship,new grad,new graduate,entry level,entry-level,junior,software engineer,swe,ml engineer,ai engineer,research engineer,machine learning,data scientist,data engineer,backend engineer,frontend engineer,full stack,fullstack,platform engineer,infrastructure engineer,site reliability,sre,devops,research scientist

# Comma-separated words that EXCLUDE a job if found in the title (whole-word match).
# "lead" won't accidentally exclude "leadership programs"; "vp" won't exclude "mvp".
EXCLUDED_KEYWORDS=senior,staff,lead,director,principal,manager,vp,head of,president,officer,distinguished,partner

# Optional location filter — only show jobs whose location contains one of these strings.
# Leave blank to see all locations (recommended).
# Example: remote,san francisco,new york,seattle
LOCATIONS=

# ============================================================
# Run behaviour
# ============================================================

# Max Discord notifications per run. Prevents channel spam if a company bulk-posts.
MAX_NOTIFICATIONS_PER_RUN=25

# Only notify jobs whose posted_at timestamp is within this window.
# Set to 0 to disable recency filtering.
RECENT_POSTING_MAX_AGE_HOURS=24

# Number of ATS company boards to fetch concurrently.
ATS_CONCURRENCY=5

# ============================================================
# SimplifyJobs scraper  (leave blank to use defaults)
# ============================================================

# Comma-separated list of SimplifyJobs raw JSON URLs.
# Default fetches both Summer internships AND New Grad positions.
# Update the Summer URL year when a new internship cycle begins (e.g. 2026 → 2027).
SIMPLIFY_URLS=https://raw.githubusercontent.com/SimplifyJobs/Summer2026-Internships/dev/.github/scripts/listings.json,https://raw.githubusercontent.com/SimplifyJobs/New-Grad-Positions/dev/.github/scripts/listings.json

# ============================================================
# HackerNews scraper  (leave blank to use defaults)
# ============================================================

# Max top-level comments to fetch from the monthly "Who is Hiring?" thread.
# HN threads have 400-800 comments; higher = broader coverage, slower run.
HN_MAX_COMMENTS=500
